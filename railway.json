{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "plan": {
        "providers": ["python"],
        "setup": {
          "python": "3.11"
        },
        "install": {
          "cmd": "pip install -r requirements.txt"
        },
        "start": {
          "cmd": "python bot.py"
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "python bot.py"
  }
}
